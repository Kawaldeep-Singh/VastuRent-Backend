# Server Settings
PORT=5000
NODE_ENV=development

# Authentication
JWT_SECRET=super_secret_broker_key_change_me
JWT_EXPIRES_IN=7d

# Default Broker Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# AI (Gemini) Configuration
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Database / Google Sheets Configuration
# The spreadsheet ID from your sheet URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account JSON Content as string, or path to credentials file
# If empty, the backend will run in Mock Mode using the local inventory.
GOOGLE_CREDENTIALS_JSON=
GOOGLE_CREDENTIALS_PATH=

# Fallback Settings
# Set to 'false' if you want to enforce strict Google Sheets loading.
# If 'true', it will use mock listings if Google Sheets API fails.
MOCK_MODE=true
